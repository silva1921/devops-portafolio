---
const portfolio = await import('../data/portfolio.json');
const { personal } = portfolio;
---

<footer class="footer">
  <div class="container">
    <div class="footer-content">
      <div class="footer-section">
        <h3>Conecta conmigo</h3>
        <div class="social-links">
          <a href={personal.github} target="_blank" rel="noopener noreferrer" class="social-link">
            🐙 GitHub
          </a>
          <a href={personal.linkedin} target="_blank" rel="noopener noreferrer" class="social-link">
            💼 LinkedIn
          </a>
          <a href={`mailto:${personal.email}`} class="social-link">
            ✉️ Email
          </a>
        </div>
      </div>
      <div class="footer-section">
        <p>&copy; 2026 {personal.name}. Todos los derechos reservados.</p>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-bg-secondary);
    border-top: 1px solid var(--color-border);
    padding: 3rem 2rem;
    margin-top: 5rem;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .footer-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    align-items: center;
  }

  .footer-section h3 {
    margin-top: 0;
    color: var(--color-primary);
  }

  .footer-section p {
    color: var(--color-text-secondary);
    margin: 0;
  }

  .social-links {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .social-link {
    display: inline-block;
    padding: 0.5rem 1rem;
    background: var(--color-bg);
    color: var(--color-text);
    text-decoration: none;
    border-radius: 0.5rem;
    transition: all 0.3s ease;
    border: 1px solid var(--color-border);
  }

  .social-link:hover {
    background: var(--color-primary);
    color: white;
    border-color: var(--color-primary);
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    .footer-content {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .footer {
      padding: 2rem;
    }
  }
</style>
